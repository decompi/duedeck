{
  "manifest_version": 3,
  "name": "DueDeck",
  "version": "0.1.0",
  "description": "A unified assignment dashboard for college deadlines.",
  "action": {
    "default_title": "DueDeck"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": ["content/canvas/entrypoints/canvas-panel-content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/canvas/styles/shadow-root.css",
        "content/canvas/components/launcher/launcher.css",
        "content/canvas/components/launcher/launcher.html",
        "content/canvas/components/panel/panel.css",
        "content/canvas/components/panel/panel.html",
        "content/canvas/components/up-next/up-next.js",
        "assets/platforms/canvas.svg",
        "assets/platforms/pearson.svg"
      ],
      "matches": [
        "https://*/*"
      ]
    }
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "permissions": ["activeTab", "scripting", "storage"]
}
