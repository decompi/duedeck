{
  "manifest_version": 3,
  "name": "DueDeck",
  "version": "0.1.0",
  "description": "An NJIT-focused assignment dashboard for Canvas deadlines.",
  "action": {
    "default_title": "DueDeck",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": ["content/canvas/entrypoints/index.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/canvas/styles/shadow-root.css",
        "content/canvas/components/launcher/launcher.css",
        "content/canvas/components/launcher/launcher.html",
        "content/canvas/components/panel/panel.css",
        "content/canvas/components/panel/panel.html",
        "content/canvas/components/panel/panel.js",
        "content/canvas/components/panel/triage.js",
        "content/canvas/components/up-next/up-next.js",
        "content/canvas/api/planner.js",
        "content/canvas/lib/date.js",
        "content/canvas/lib/storage.js",
        "content/canvas/entrypoints/main.js",
        "assets/platforms/canvas.svg"
      ],
      "matches": [
        "https://*/*"
      ]
    }
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "permissions": ["activeTab", "alarms", "notifications", "scripting", "storage"]
}
